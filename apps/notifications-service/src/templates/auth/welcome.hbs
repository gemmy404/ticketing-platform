<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Welcome to EventHub</title>
</head>

<body style="margin:0;padding:40px;background:#f4f6f8;font-family:Arial,Helvetica,sans-serif;color:#333;">

<div style="max-width:600px;margin:auto;background:#ffffff;border-radius:8px;padding:40px;">

    <h1 style="margin-top:0;color:#2563eb;">
