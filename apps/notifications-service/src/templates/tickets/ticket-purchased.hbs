<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Ticket Purchased</title>
</head>

<body style="margin:0;padding:40px;background:#f4f6f8;font-family:Arial,Helvetica,sans-serif;color:#333;">

<div style="max-width:650px;margin:auto;background:#ffffff;border-radius:8px;padding:40px;">

    <h1 style="margin-top:0;color:#16a34a;">
        Ticket Confirmed
    </h1>

    <p>Hi <strong>{{name}}</strong>,</p>

    <p>
        Your ticket has been successfully purchased for the following event:
    </p>

    <table style="width:100%;border-collapse:collapse;margin:25px 0;">
        <tr>
            <td style="padding:10px;font-weight:bold;">Event</td>
            <td>{{eventTitle}}</td>
        </tr>

        <tr style="background:#f9fafb;">
            <td style="padding:10px;font-weight:bold;">Date</td>
            <td>{{eventDate}}</td>
        </tr>

        <tr>
            <td style="padding:10px;font-weight:bold;">Location</td>
            <td>{{eventLocation}}</td>
        </tr>

        <tr style="background:#f9fafb;">
            <td style="padding:10px;font-weight:bold;">Quantity</td>
            <td>{{quantity}}</td>
        </tr>

        <tr>
            <td style="padding:10px;font-weight:bold;">Total Price</td>
            <td>${{totalPrice}}</td>
        </tr>

        <tr style="background:#f9fafb;">
            <td style="padding:10px;font-weight:bold;">Ticket Code</td>
            <td>
                <strong style="font-size:18px;color:#2563eb;">
                    {{ticketCode}}
                </strong>
            </td>
        </tr>
    </table>

    <p>
        Please keep your ticket code safe.
        You'll need it during event check-in.
    </p>

    <hr style="margin:30px 0;border:none;border-top:1px solid #e5e7eb;">

    <p style="font-size:14px;color:#6b7280;">
        Thank you for choosing <strong>EventHub</strong>.<br>
        We hope you enjoy the event!
    </p>

</div>

</body>

</html>